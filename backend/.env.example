# ============================================================
# Calimuv Backend — environment variables
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# ============================================================

# --- Application ---
PROJECT_NAME=Calimuv API
ENVIRONMENT=development          # development | production
DEBUG=true

# --- Database ---
# Local dev (default): SQLite file, no install required.
DATABASE_URL=sqlite:///./calimuv.db
# Production (Supabase) — set this ONLY in the Render dashboard, never commit it:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# --- Security / JWT ---
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120
ALGORITHM=HS256

# --- First admin (used by seed script to create your login) ---
FIRST_ADMIN_EMAIL=admin@calimuv.com
FIRST_ADMIN_PASSWORD=ChangeMe123!
FIRST_ADMIN_NAME=Calimuv Admin

# --- CORS (comma-separated origins allowed to call the API) ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Cloudinary (added in Step 9; leave blank for now) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
